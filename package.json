{
  "name": "lina",
  "version": "0.1.9",
  "description": "Assistente para pesquisa semântica, organização e enriquecimento de notas Markdown.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "release-check": "node scripts/release-check.js",
    "release:bump": "node scripts/bump-version.js",
    "release:validate": "npm run typecheck && npm run build && npm run release-check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:index": "vitest run tests/index"
  },
  "keywords": [],
  "author": "Anselmo Pinheiro",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "@typescript-eslint/eslint-plugin": "5.29.0",
    "@typescript-eslint/parser": "5.29.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "^1.12.1",
    "tslib": "2.4.0",
    "typescript": "4.7.4",
    "vitest": "^3.2.7"
  }
}